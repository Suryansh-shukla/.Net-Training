html
@model DtoLab.ViewModels.UserListViewModel

@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>

<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="searchTerm" value="@Model.SearchTerm"
                   class="form-control" placeholder="Search users..." />
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input type="checkbox" name="adminsOnly" value="true"
                       class="form-check-input" id="adminsOnly"
                @(Model.ShowAdminsOnly ? "checked" : "") />
                <label class="form-check-label" for="adminsOnly">Admins only</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<p>Total users: @Model.TotalUsers</p>

<div class="row">
    @foreach (var user in Model.Users)
    {
        <div class="col-md-4 mb-3">
            <div class="card @(user.IsBirthdayMonth ? "border-primary" : "")">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="bg-secondary text-white rounded-circle d-flex
                            justify-content-center align-items-center me-2"
                             style="width: 40px; height: 40px;">
                            @user.AvatarInitials
                        </div>
                        <h5 class="mb-0">@user.DisplayName</h5>
                    </div>
                    @if (user.IsBirthdayMonth)
                    {
                        <span class="badge bg-success">Birthday Month! 🎂</span>
                    }
                </div>
                <div class="card-body">
                    <p class="card-text">
                        <strong>Email:</strong> @user.Email<br />
                        <strong>Age:</strong> @user.Age<br />
                        <strong>Member since:</strong> @user.MemberSince
                    </p>
                    <a asp-action="Details" asp-route-id="@user.Id"
                       class="btn btn-sm btn-primary">View Profile</a>
                </div>
            </div>
        </div>
    }
</div>