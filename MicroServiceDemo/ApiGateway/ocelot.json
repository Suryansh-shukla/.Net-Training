{
  "Routes": [
    {
      "Name": "OrderServiceAPI",
      "DownstreamPathTemplate": "/api/orders/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          //"Host": "order-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/orders/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AddHeadersToRequest": {
        "X-Correlation-Id": "CorrelationId"
      },
      "RouteClaimsRequirement": {
        "UserRole": "customer"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 100
      },
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 10000,
        "TimeoutValue": 5000
      },
      "LoadBalancerOptions": {
        "Type": "LeastConnection",
        "Key": "order-service",
        "Expiry": 60000
      },
      "HttpHandlerOptions": {
        "AllowAutoRedirect": false,
        "UseCookieContainer": false,
        "UseTracing": true
      }
    },
    {
      "Name": "PaymentServiceAPI",
      "DownstreamPathTemplate": "/api/payments/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          //"Host": "payment-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/payments/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 50
      },
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 2,
        "DurationOfBreak": 5000,
        "TimeoutValue": 3000
      }
    },
    {
      "Name": "ShippingServiceAPI",
      "DownstreamPathTemplate": "/api/shipping/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          //"Host": "shipping-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/shipping/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 50
      }
    },
    {
      "Name": "OrderServiceSwagger",
      "DownstreamPathTemplate": "/swagger/orders/swagger.json",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          //"Host": "order-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/swagger/orders/swagger.json",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "Name": "PaymentServiceSwagger",
      "DownstreamPathTemplate": "/swagger/payments/swagger.json",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          //"Host": "payment-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/swagger/payments/swagger.json",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "Name": "ShippingServiceSwagger",
      "DownstreamPathTemplate": "/swagger/shipping/swagger.json",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          // "Host": "shipping-service",
          "Host": "localhost",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/swagger/shipping/swagger.json",
      "UpstreamHttpMethod": [ "GET" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "GatewayName": "MicroserviceDemoGateway",
    "RequestIdKey": "OcRequestId",
    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "QuotaExceededMessage": "Rate limit exceeded. Please try again later.",
      "HttpStatusCode": 429
    },
    "QoSOptions": {
      "ExceptionsAllowedBeforeBreaking": 3,
      "DurationOfBreak": 10000,
      "TimeoutValue": 5000
    },
    "LoadBalancerOptions": {
      "Type": "LeastConnection"
    },
    "ServiceDiscoveryProvider": {
      "Type": "Consul",
      "Host": "consul",
      "Port": 8500,
      "Scheme": "http"
    }
  }
}